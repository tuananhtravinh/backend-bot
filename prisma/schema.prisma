// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())  
  email     String   @unique
  password  String
  username  String   @unique // Thêm trường username nếu bạn dùng nó
  firstName String?
  lastName  String?  
  role      String   @default("BUYER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  
  @@map("users")
}